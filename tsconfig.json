{
  "compilerOptions": {
    "target": "ES2020",
    "module": "esnext",
    "rootDir": "src",
    "outDir": "dist",

    "strict": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "sourceMap": true,
    "skipLibCheck": true,

    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}